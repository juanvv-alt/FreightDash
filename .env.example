# Django Configuration
DEBUG=False
SECRET_KEY=your-super-secret-key-generate-with-django-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=freightdash
DATABASE_USER=postgres
DATABASE_PASSWORD=your-secure-password
DATABASE_HOST=db
DATABASE_PORT=5432

# CORS & Security
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# Render-specific (for production deployment)
ENVIRONMENT=production
REGION=sg

# Optional: Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Optional: AWS S3 for static/media files
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1

# Supply forecast: free AIS feed from https://aisstream.io (one connection per key).
# Used by the `ingest_ais` worker; leave blank to run --replay mode only.
AISSTREAM_API_KEY=
