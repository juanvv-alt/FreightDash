# Copy this file to .env on your Synology and fill in the values below.
# Place it in the same folder as docker-compose.synology.yml.

# Django secret key — generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-this-with-a-long-random-string

# Database credentials
COMPOSE_DB_NAME=freightdash
COMPOSE_DB_USER=postgres
COMPOSE_DB_PASSWORD=choose-a-strong-password

# Replace 192.168.1.x with your Synology's actual local IP address
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.x
CSRF_TRUSTED_ORIGINS=http://192.168.1.x:8000
